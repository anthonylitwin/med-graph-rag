# API
API_PORT=8000

# WEB
VITE_API_BASE_URL=http://localhost:8000

# Neo4j
# Inside docker network
NEO4J_URI=bolt://neo4j:7687
# From host machine
NEO4J_LOCAL_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=medgraphrag-password

# OpenAI extraction
OPENAI_API_KEY=put-openai-api-key-here
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium

# Model runtime profiles
# Supported: frontier, local-qwen25, local-qwen3, noop
MODEL_PROFILE=frontier
LOCAL_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434
EXTRACTOR_ENTITY_MODEL=Ihor/gliner-biomed-small-v1.0
GLINER_ENTITY_THRESHOLD=0.35

# Optional explicit overrides; usually leave these unset and use MODEL_PROFILE.
# QA_PROVIDER=openai
# QA_MODEL=gpt-5.5
# QA_RETRIEVER=graph
# EXTRACTOR_PROVIDER=openai
# EXTRACTOR_MODEL=gpt-5.5

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# MinIO
MINIO_ROOT_USER=medgraphrag
MINIO_ROOT_PASSWORD=medgraphrag-password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=medgraphrag-artifacts
AWS_ACCESS_KEY=put-key-here
AWS_SECRET_ACCESS_KEY=put-secret-here
AWS_DEFAULT_REGION=us-east-1

# Example environment variables
APP_ENV=development
API_HOST=0.0.0.0
UI_PORT=8501
